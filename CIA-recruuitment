<title>وكالة الاستخبارات المركزية — تقديم</title>
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Cairo:wght@300;400;600;700;900&display=swap" rel="stylesheet">
<style>
  :root {
    --green: #00ff41;
    --green-dim: #00cc33;
    --green-dark: #003311;
    --bg: #020a02;
    --surface: #050f05;
    --border: #0a2a0a;
    --red: #ff2020;
    --gold: #c8a200;
    --text: #c8ffc8;
    --text-dim: #558855;
  }

- { margin: 0; padding: 0; box-sizing: border-box; }

body {
background: var(–bg);
color: var(–text);
font-family: ‘Cairo’, sans-serif;
min-height: 100vh;
overflow-x: hidden;
position: relative;
}

/* Scanlines */
body::before {
content: ‘’;
position: fixed;
inset: 0;
background: repeating-linear-gradient(
0deg,
transparent,
transparent 2px,
rgba(0,255,65,0.015) 2px,
rgba(0,255,65,0.015) 4px
);
pointer-events: none;
z-index: 1000;
}

/* Matrix rain canvas */
#matrix-canvas {
position: fixed;
top: 0; left: 0;
width: 100%; height: 100%;
opacity: 0.07;
z-index: 0;
pointer-events: none;
}

.container {
position: relative;
z-index: 1;
max-width: 860px;
margin: 0 auto;
padding: 40px 20px 80px;
}

/* Header */
.header {
text-align: center;
margin-bottom: 50px;
padding: 40px 20px;
border: 1px solid var(–green-dark);
position: relative;
background: rgba(0,255,65,0.02);
}

.header::before, .header::after {
content: ‘’;
position: absolute;
width: 20px; height: 20px;
border-color: var(–green);
border-style: solid;
}
.header::before { top: -1px; right: -1px; border-width: 2px 2px 0 0; }
.header::after  { bottom: -1px; left: -1px; border-width: 0 0 2px 2px; }

.classified-tag {
font-family: ‘Share Tech Mono’, monospace;
font-size: 11px;
letter-spacing: 8px;
color: var(–red);
margin-bottom: 16px;
animation: blink 2s step-end infinite;
}

@keyframes blink { 50% { opacity: 0; } }

.cia-seal {
width: 130px;
height: 130px;
margin: 0 auto 20px;
border-radius: 50%;
border: 2px solid var(–green);
display: flex;
align-items: center;
justify-content: center;
background: #000;
box-shadow: 0 0 30px rgba(0,255,65,0.25), inset 0 0 20px rgba(0,255,65,0.05);
animation: pulse-glow 3s ease-in-out infinite;
overflow: hidden;
}

@keyframes pulse-glow {
0%, 100% { box-shadow: 0 0 20px rgba(0,255,65,0.2), inset 0 0 20px rgba(0,255,65,0.05); }
50% { box-shadow: 0 0 50px rgba(0,255,65,0.4), inset 0 0 30px rgba(0,255,65,0.1); }
}

.header h1 {
font-size: 13px;
font-family: ‘Share Tech Mono’, monospace;
letter-spacing: 6px;
color: var(–green-dim);
margin-bottom: 8px;
}

.header h2 {
font-size: clamp(22px, 5vw, 36px);
font-weight: 900;
color: var(–green);
text-shadow: 0 0 20px rgba(0,255,65,0.5);
margin-bottom: 6px;
}

.header-sub {
font-family: ‘Share Tech Mono’, monospace;
font-size: 11px;
color: var(–text-dim);
letter-spacing: 3px;
}

/* Section */
.section {
margin-bottom: 40px;
border: 1px solid var(–border);
background: rgba(0,255,65,0.01);
overflow: hidden;
}

.section-header {
background: rgba(0,255,65,0.07);
border-bottom: 1px solid var(–border);
padding: 14px 20px;
font-family: ‘Share Tech Mono’, monospace;
font-size: 12px;
letter-spacing: 5px;
color: var(–green);
display: flex;
align-items: center;
gap: 10px;
}

.section-header span { color: var(–text-dim); }

.section-body { padding: 24px 20px; }

/* Form elements */
.form-group {
margin-bottom: 24px;
}

label {
display: block;
font-size: 14px;
font-weight: 600;
color: var(–text);
margin-bottom: 8px;
line-height: 1.5;
}

label .req {
color: var(–red);
margin-right: 4px;
font-size: 16px;
}

input[type=“text”],
textarea,
select {
width: 100%;
background: rgba(0,20,0,0.8);
border: 1px solid #0d3a0d;
color: var(–green);
font-family: ‘Cairo’, sans-serif;
font-size: 14px;
padding: 12px 14px;
outline: none;
transition: border-color 0.2s, box-shadow 0.2s;
-webkit-appearance: none;
border-radius: 0;
direction: rtl;
}

input[type=“text”]:focus,
textarea:focus,
select:focus {
border-color: var(–green-dim);
box-shadow: 0 0 12px rgba(0,255,65,0.1);
}

input[type=“text”]::placeholder,
textarea::placeholder {
color: #1a4a1a;
font-family: ‘Cairo’, sans-serif;
}

textarea {
resize: vertical;
min-height: 100px;
}

select option {
background: #050f05;
color: var(–green);
}

/* File upload */
.file-upload-wrapper {
position: relative;
}

input[type=“file”] {
width: 100%;
background: rgba(0,20,0,0.8);
border: 1px dashed #0d3a0d;
color: var(–text-dim);
font-family: ‘Share Tech Mono’, monospace;
font-size: 12px;
padding: 16px;
cursor: pointer;
transition: border-color 0.2s;
direction: ltr;
}

input[type=“file”]:hover { border-color: var(–green-dim); }

.file-label {
display: block;
font-size: 11px;
color: var(–text-dim);
margin-top: 6px;
font-family: ‘Share Tech Mono’, monospace;
}

/* Radio group */
.radio-group {
display: flex;
gap: 12px;
flex-wrap: wrap;
margin-top: 4px;
}

.radio-btn {
flex: 1;
min-width: 80px;
}

.radio-btn input[type=“radio”] { display: none; }

.radio-btn label {
display: block;
text-align: center;
padding: 10px 16px;
border: 1px solid #0d3a0d;
cursor: pointer;
font-size: 13px;
font-weight: 700;
transition: all 0.2s;
background: rgba(0,15,0,0.8);
color: var(–text-dim);
margin: 0;
}

.radio-btn input[type=“radio”]:checked + label {
border-color: var(–green);
color: var(–green);
background: rgba(0,255,65,0.08);
box-shadow: 0 0 10px rgba(0,255,65,0.15);
}

.radio-btn label:hover {
border-color: var(–green-dim);
color: var(–green-dim);
}

/* Yes/No specific */
.yn-group { max-width: 300px; }

/* Divider */
.divider {
border: none;
border-top: 1px solid var(–border);
margin: 20px 0;
}

/* Submit */
.submit-section {
text-align: center;
padding: 30px 20px;
border: 1px solid var(–border);
background: rgba(0,255,65,0.02);
position: relative;
}

.submit-btn {
background: transparent;
border: 2px solid var(–green);
color: var(–green);
font-family: ‘Cairo’, sans-serif;
font-size: 16px;
font-weight: 700;
letter-spacing: 4px;
padding: 16px 60px;
cursor: pointer;
position: relative;
overflow: hidden;
transition: all 0.3s;
text-transform: uppercase;
}

.submit-btn::before {
content: ‘’;
position: absolute;
inset: 0;
background: var(–green);
transform: scaleX(0);
transform-origin: left;
transition: transform 0.3s ease;
z-index: -1;
}

.submit-btn:hover {
color: var(–bg);
box-shadow: 0 0 30px rgba(0,255,65,0.4);
}

.submit-btn:hover::before { transform: scaleX(1); }

.submit-btn:disabled {
opacity: 0.4;
cursor: not-allowed;
}

/* Status message */
#status-msg {
margin-top: 20px;
font-family: ‘Share Tech Mono’, monospace;
font-size: 13px;
letter-spacing: 2px;
min-height: 20px;
}

.status-success { color: var(–green); }
.status-error { color: var(–red); }

/* Footer */
.footer {
text-align: center;
margin-top: 40px;
font-family: ‘Share Tech Mono’, monospace;
font-size: 10px;
color: #1a3a1a;
letter-spacing: 4px;
}

/* Glitch effect on hover for sections */
.section:hover { border-color: #0d3a0d; }

/* Scrollbar */
::-webkit-scrollbar { width: 4px; }
::-webkit-scrollbar-track { background: var(–bg); }
::-webkit-scrollbar-thumb { background: #0d3a0d; }
::-webkit-scrollbar-thumb:hover { background: var(–green-dim); }

/* Error highlight */
.field-error {
border-color: var(–red) !important;
box-shadow: 0 0 8px rgba(255,32,32,0.2) !important;
}

.error-msg {
color: var(–red);
font-size: 11px;
font-family: ‘Share Tech Mono’, monospace;
margin-top: 4px;
display: none;
}

/* Loading spinner */
.spinner {
display: inline-block;
width: 14px; height: 14px;
border: 2px solid rgba(0,255,65,0.3);
border-top-color: var(–green);
border-radius: 50%;
animation: spin 0.8s linear infinite;
vertical-align: middle;
margin-left: 8px;
}
@keyframes spin { to { transform: rotate(360deg); } }
</style>

</head>
