<script>
// ═══ Matrix rain ═══
const canvas = document.getElementById('matrix-canvas');
const ctx = canvas.getContext('2d');
canvas.width = window.innerWidth;
canvas.height = window.innerHeight;
const cols = Math.floor(canvas.width / 16);
const drops = Array(cols).fill(1);
const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789@#$%^&*()CIA';
function drawMatrix() {
  ctx.fillStyle = 'rgba(2,10,2,0.05)';
  ctx.fillRect(0, 0, canvas.width, canvas.height);
  ctx.fillStyle = '#00ff41';
  ctx.font = '13px Share Tech Mono';
  drops.forEach((y, i) => {
    const c = chars[Math.floor(Math.random() * chars.length)];
    ctx.fillText(c, i * 16, y * 16);
    if (y * 16 > canvas.height && Math.random() > 0.975) drops[i] = 0;
    drops[i]++;
  });
}
setInterval(drawMatrix, 50);
window.addEventListener('resize', () => { canvas.width = window.innerWidth; canvas.height = window.innerHeight; });

// ═══ Firebase helpers ═══
let _cachedApps = [];

// Listen to Firebase in real-time
function initFirebaseListener() {
  if (!window._onValue) { setTimeout(initFirebaseListener, 200); return; }
  window._onValue(window._appsRef, (snapshot) => {
    const data = snapshot.val();
    if (data) {
      _cachedApps = Object.entries(data).map(([key, val]) => ({ ...val, _key: key }));
      _cachedApps.sort((a, b) => b.id - a.id);
    } else {
      _cachedApps = [];
    }
  });
}
initFirebaseListener();

function getApps() { return _cachedApps; }

function addApp(data) {
  if (!window._push) return;
  const newApp = { ...data, id: Date.now(), timestamp: new Date().toLocaleString('ar-SA') };
  window._push(window._appsRef, newApp);
}

function saveApps(apps) {
  // Used for clearAll - delete each app
  if (!window._ref || !window._set) return;
  window._set(window._appsRef, null);
}

// ═══ Collect / Validate ═══
function collectData() {
  const g = id => document.getElementById(id);
  const radio = name => { const el = document.querySelector(`input[name="${name}"]:checked`); return el ? el.value : '—'; };
  return {
    discord: g('discord').value.trim(),
    real_name: g('real-name').value.trim(),
    real_age: g('real-age').value.trim(),
    game_name: g('game-name').value.trim(),
