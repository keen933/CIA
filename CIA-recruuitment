    q6: radio('q6'), q7: radio('q7'), q8: radio('q8'), q9: radio('q9'), q10: radio('q10'),
  };
}

function validate() {
  let ok = true;
  const show = id => { document.getElementById(id).style.display = 'block'; ok = false; };
  const hide = id => { document.getElementById(id).style.display = 'none'; };
  const req = [
    ['discord','err-discord'],['real-name','err-real-name'],['real-age','err-real-age'],
    ['game-name','err-game-name'],['reason','err-reason'],['advantage','err-advantage'],
    ['skills','err-skills'],['affiliations','err-affiliations'],['diff','err-diff'],
    ['cia-role','err-cia-role'],['group-mission','err-group-mission'],
    ['secret-mission','err-secret-mission'],['sector-reason','err-sector-reason'],
  ];
  req.forEach(([fid, eid]) => {
    const el = document.getElementById(fid);
    if (!el.value.trim()) { el.classList.add('field-error'); show(eid); }
    else { el.classList.remove('field-error'); hide(eid); }
  });
  ['sector','q1','q2','q3','q4','q5','q6','q7','q8','q9','q10'].forEach(name => {
    const eid = 'err-' + name;
    if (!document.querySelector(`input[name="${name}"]:checked`)) show(eid);
    else hide(eid);
  });
  return ok;
}

