        td(`<span style="font-family:'Share Tech Mono',monospace;font-size:12px;color:#aaddaa;">${app.real_age || '—'}</span>`) +
        td(`<span style="font-size:13px;color:#c8ffc8;">${app.game_name || '—'}</span>`) +
        td(`<span style="border:1px solid ${color}33;background:${color}11;color:${color};padding:3px 10px;font-size:12px;font-weight:700;white-space:nowrap;">${app.sector || '—'}</span>`) +
        td(`<span style="font-size:12px;color:#aaddaa;">${truncate(app.reason,60)}</span><br><span onclick='showDetail(${app.id})' style="font-family:'Share Tech Mono',monospace;font-size:10px;color:#336633;cursor:pointer;letter-spacing:2px;" onmouseover="this.style.color='#00ff41'" onmouseout="this.style.color='#336633'">▶ عرض كامل</span>`) +
        td(`<span style="font-size:12px;color:#aaddaa;">${truncate(app.skills,50)}</span>`) +
        td(`<span style="font-size:12px;color:#aaddaa;">${truncate(app.affiliations,50)}</span>`) +
        td(`<span style="font-size:12px;color:#aaddaa;">${truncate(app.cia_role,50)}</span>`) +
        td(`<span style="font-size:12px;color:#aaddaa;">${truncate(app.group_mission,50)}</span>`) +
        td(`<span style="font-size:12px;color:#aaddaa;">${truncate(app.secret_mission,50)}</span>`) +
        td(`<span style="font-size:12px;color:#aaddaa;">${truncate(app.sector_reason,50)}</span>`) +
        td(`
          <div style="text-align:center;">
            <div style="font-family:'Share Tech Mono',monospace;font-size:18px;color:${yesCount>=8?'#00ff41':'#cc3333'};">${yesCount}/10</div>
            <div style="font-family:'Share Tech Mono',monospace;font-size:9px;color:#336633;letter-spacing:1px;">موافقات</div>
          </div>
        `, 'text-align:center;') +
        `<td style="padding:11px 10px;text-align:center;vertical-align:top;">
          <button onclick="deleteApp(${app.id})" style="
            background:transparent;border:1px solid #3a0d0d;color:#662222;
            font-family:'Share Tech Mono',monospace;font-size:10px;padding:4px 10px;
            cursor:pointer;letter-spacing:1px;transition:all 0.2s;
          " onmouseover="this.style.color='#ff2020';this.style.borderColor='#ff2020'"
             onmouseout="this.style.color='#662222';this.style.borderColor='#3a0d0d'">حذف</button>
        </td>`;

      tbody.appendChild(row);
    });
  }

  document.getElementById('admin-panel').style.display = 'block';
  document.body.style.overflow = 'hidden';
}

function closeAdminPanel() {
  document.getElementById('admin-panel').style.display = 'none';
  document.body.style.overflow = '';
}

function deleteApp(id) {
  if (!confirm('هل تريد حذف هذا التقديم؟')) return;
  const app = _cachedApps.find(a => a.id === id);
  if (app && app._key && window._ref && window._remove) {
    window._remove(window._ref(window._db, 'applications/' + app._key));
    setTimeout(openAdminPanel, 500);
  }
}

function clearAllApplications() {
  if (!confirm('هل أنت متأكد من حذف جميع التقديمات؟')) return;
  if (window._set && window._ref && window._db) {
    window._set(window._ref(window._db, 'applications'), null);
    setTimeout(openAdminPanel, 500);
  }
}

function showDetail(id) {
  const app = getApps().find(a => a.id === id);
  if (!app) return;
  const color = sectorColor[app.sector] || '#00ff41';
  const row = (label, val) => `
    <div style="border-bottom:1px solid #0a1a0a;padding:10px 0;display:flex;gap:12px;align-items:flex-start;">
      <span style="font-family:'Share Tech Mono',monospace;font-size:10px;color:#336633;letter-spacing:2px;white-space:nowrap;min-width:160px;padding-top:2px;">${label}</span>
      <span style="color:#c8ffc8;font-size:13px;line-height:1.6;">${val || '—'}</span>
    </div>`;

  document.getElementById('detail-content').innerHTML = `
    <div style="font-family:'Share Tech Mono',monospace;font-size:10px;color:#ff2020;letter-spacing:6px;text-align:center;margin-bottom:20px;animation:blink 2s step-end infinite;">◆ CLASSIFIED — AGENT FILE ◆</div>
    <div style="font-size:20px;font-weight:900;color:#00ff41;text-align:center;margin-bottom:4px;">${app.discord}</div>
    <div style="font-family:'Share Tech Mono',monospace;font-size:10px;color:#336633;text-align:center;margin-bottom:24px;">${app.timestamp}</div>

    <div style="border:1px solid ${color}33;background:${color}08;padding:10px 16px;text-align:center;margin-bottom:20px;">
      <span style="color:${color};font-size:15px;font-weight:700;">القطاع: ${app.sector}</span>
    </div>

    ${row('الاسم الحقيقي', app.real_name)}
    ${row('العمر', app.real_age)}
    ${row('الاسم باللعبة', app.game_name)}
    ${row('سبب التقديم', app.reason)}
    ${row('ما يجعله أفضل', app.advantage)}
    ${row('المهارات', app.skills)}
    ${row('الانتماءات', app.affiliations)}
    ${row('الفرق سري/جماعي', app.diff)}
    ${row('وظيفة CIA', app.cia_role)}
    ${row('مهمة جماعية', app.group_mission)}
    ${row('مهمة سرية', app.secret_mission)}
    ${row('سبب القطاع', app.sector_reason)}

    <div style="margin-top:20px;border:1px solid #0a2a0a;padding:16px;">
      <div style="font-family:'Share Tech Mono',monospace;font-size:10px;letter-spacing:4px;color:#558855;margin-bottom:14px;">الموافقات — AGREEMENTS</div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">
        ${[
          ['خدمة القطاع', app.q1], ['العمل اليومي', app.q2],
          ['السرية التامة', app.q3], ['التدريب 3 أيام', app.q4],
          ['اتباع الأوامر', app.q5], ['المحكمة السرية', app.q6],
          ['إعدام (فساد)', app.q7], ['إعدام (استقالة)', app.q8],
          ['جميع الإجراءات', app.q9], ['تأكيد التوقيع', app.q10],
        ].map(([l,v]) => `<div style="font-size:12px;display:flex;justify-content:space-between;padding:4px 8px;border:1px solid #0a1a0a;">
          <span style="color:#558855;">${l}</span>
          <span style="font-weight:700;color:${v==='نعم'?'#00ff41':'#ff2020'};">${v}</span>
        </div>`).join('')}
      </div>
    </div>
  `;
  document.getElementById('detail-modal').style.display = 'block';
}
</script>

</body>
</html>
